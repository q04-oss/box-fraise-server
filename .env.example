# ── Database URLs ────────────────────────────────────────────────────
# Two roles, on purpose. The migration role is the table owner (the
# Postgres superuser from docker-compose), the runtime role is `bf_app`
# — restricted, no BYPASSRLS. The split is what makes RLS actually
# enforce.

# Used by `sqlx migrate run` only.
MIGRATION_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/box_fraise

# Used by the running app.
DATABASE_URL=postgresql://bf_app:bf_app@localhost:5434/box_fraise

# ── Server ───────────────────────────────────────────────────────────
BIND_ADDR=0.0.0.0:3000

# Comma-separated allowlist. Native iOS does not enforce CORS, so this
# only matters when the admin tool is served from a different origin in
# the future. Localhost in dev is fine.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Admin session lifetime (12h default).
ADMIN_SESSION_TTL_SECS=43200

# Challenge nonce TTL — short enough to make screenshot replay useless.
CHALLENGE_TTL_SECS=120

# ── First-boot seed admin ────────────────────────────────────────────
# Without this, the admin tool is locked out — there is no admin signup
# endpoint. Set both once; the seed is idempotent. Rotate the password
# out of env after a real admin-rotation flow lands.
SEED_ADMIN_EMAIL=admin@boxfraise.local
SEED_ADMIN_PASSWORD=changeMe!Now123
